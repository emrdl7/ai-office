# AI Office 환경변수 설정
# 이 파일을 .env로 복사한 후 값을 채우세요

# === 필수 ===
# Groq API 키 (무료, https://console.groq.com/keys)
GROQ_API_KEY=gsk_여기에_키_입력

# === 선택 (경로 커스텀) ===
# Claude CLI 경로 (기본: claude)
# CLAUDE_CLI=/path/to/claude

# OpenCode CLI 경로 (기본: opencode)
# OPENCODE_CLI=/path/to/opencode

# === 선택 (Stitch 디자인 생성) ===
# STITCH_API_KEY=
# STITCH_PROJECT_ID=
